generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER 
  ADMIN
}

//Comando: npx prisma db push - para criar a tabela do banco de dados
//Comando: npx prisma db pull - para atualizar o schema.prisam com as tabelas do banco dados
model User {
  id          Int       @id @default(autoincrement())
  name        String 
  email       String    @unique
  status      Boolean   @default(true)
  role        Role      @default(USER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  posts       Post[]

  @@map("users")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  content   String
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("posts")
}
